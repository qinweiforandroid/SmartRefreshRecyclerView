<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bili_page_bg"
    android:orientation="vertical">

    <FrameLayout
        android:id="@+id/mPlayerContainer"
        android:layout_width="match_parent"
        android:layout_height="@dimen/player_bili_height"
        android:background="@android:color/black"
        android:keepScreenOn="true">

        <androidx.media3.ui.PlayerView
            android:id="@+id/mPlayerView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@android:color/black"
            app:resize_mode="fit"
            app:show_buffering="when_playing"
            app:use_controller="false" />

        <View
            android:id="@+id/mTopScrim"
            android:layout_width="match_parent"
            android:layout_height="108dp"
            android:background="@drawable/bg_player_top_scrim" />

        <View
            android:id="@+id/mBottomScrim"
            android:layout_width="match_parent"
            android:layout_height="144dp"
            android:layout_gravity="bottom"
            android:background="@drawable/bg_player_bottom_scrim" />

        <LinearLayout
            android:id="@+id/mControlOverlay"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clickable="true"
            android:focusable="true"
            android:orientation="vertical"
            android:padding="14dp">

            <LinearLayout
                android:id="@+id/mTopControls"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:id="@+id/mBackBtn"
                    android:layout_width="38dp"
                    android:layout_height="38dp"
                    android:background="@drawable/bg_bili_control_button"
                    android:padding="9dp"
                    android:src="@drawable/ic_player_back"
                    android:contentDescription="@string/player_back" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/mOverlayTitleLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:maxLines="1"
                        android:text="@string/player_title"
                        android:textColor="@android:color/white"
                        android:textSize="17sp"
                        android:textStyle="bold" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/mLiveBadgeLabel"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:background="@drawable/bg_bili_chip_dark"
                            android:paddingStart="8dp"
                            android:paddingTop="3dp"
                            android:paddingEnd="8dp"
                            android:paddingBottom="3dp"
                            android:text="@string/player_live_badge"
                            android:textColor="@android:color/white"
                            android:textSize="11sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/mClockLabel"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:text="@string/player_clock_placeholder"
                            android:textColor="@android:color/white"
                            android:textSize="12sp" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:gravity="bottom" />

            <LinearLayout
                android:id="@+id/mBottomControls"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="64dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <FrameLayout
                            android:id="@+id/mPlayPauseBtn"
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:layout_marginStart="2dp"
                            android:layout_marginEnd="8dp"
                            android:foreground="?attr/selectableItemBackgroundBorderless"
                            android:padding="4dp">

                            <ImageView
                                android:id="@+id/mPlayPauseIcon"
                                android:layout_width="24dp"
                                android:layout_height="24dp"
                                android:layout_gravity="center"
                                android:src="@drawable/ic_player_pause"
                                android:contentDescription="@string/player_pause" />
                        </FrameLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <SeekBar
                                android:id="@+id/mSeekBar"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:max="1000"
                                android:minHeight="18dp"
                                android:progressTint="@color/bili_pink"
                                android:thumbTint="@color/bili_pink" />

                            <TextView
                                android:id="@+id/mProgressLabel"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="6dp"
                                android:layout_marginEnd="10dp"
                                android:text="00:00/00:00"
                                android:textColor="@android:color/white"
                                android:textSize="12sp"
                                android:textStyle="bold" />
                        </LinearLayout>

                        <LinearLayout
                            android:id="@+id/mOrientationBtn"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="10dp"
                            android:gravity="center_horizontal"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/mOrientationText"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginBottom="2dp"
                                android:background="@drawable/bg_bili_chip_dark"
                                android:paddingStart="6dp"
                                android:paddingTop="1dp"
                                android:paddingEnd="6dp"
                                android:paddingBottom="1dp"
                                android:text="竖屏"
                                android:textColor="@android:color/white"
                                android:textSize="10sp"
                                android:visibility="gone" />

                            <FrameLayout
                                android:layout_width="32dp"
                                android:layout_height="32dp"
                                android:foreground="?attr/selectableItemBackgroundBorderless"
                                android:padding="2dp">

                                <ImageView
                                    android:id="@+id/mOrientationIcon"
                                    android:layout_width="18dp"
                                    android:layout_height="18dp"
                                    android:layout_gravity="center"
                                    android:src="@drawable/ic_player_portrait"
                                    android:contentDescription="竖屏" />
                            </FrameLayout>
                        </LinearLayout>

                        <FrameLayout
                            android:id="@+id/mFullscreenBtn"
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:foreground="?attr/selectableItemBackgroundBorderless"
                            android:padding="2dp">

                            <ImageView
                                android:id="@+id/mFullscreenIcon"
                                android:layout_width="18dp"
                                android:layout_height="18dp"
                                android:layout_gravity="center"
                                android:src="@drawable/ic_player_fullscreen"
                                android:contentDescription="@string/player_fullscreen" />
                        </FrameLayout>
                    </LinearLayout>
                </FrameLayout>

                <Space
                    android:layout_width="match_parent"
                    android:layout_height="2dp" />
            </LinearLayout>
        </LinearLayout>
    </FrameLayout>

    <LinearLayout
        android:id="@+id/mDetailContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_bili_surface_card"
        android:orientation="vertical"
        android:paddingStart="18dp"
        android:paddingTop="18dp"
        android:paddingEnd="18dp"
        android:paddingBottom="12dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/mAvatarLabel"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="@drawable/bg_avatar_circle"
                android:gravity="center"
                android:text="TV"
                android:textColor="@android:color/white"
                android:textSize="16sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/mAuthorNameLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/player_author_name"
                    android:textColor="@color/bili_text_primary"
                    android:textSize="17sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/mAuthorMetaLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="@string/player_author_meta"
                    android:textColor="@color/bili_text_secondary"
                    android:textSize="13sp" />
            </LinearLayout>

            <TextView
                android:id="@+id/mFollowBtn"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_bili_follow"
                android:paddingStart="16dp"
                android:paddingTop="9dp"
                android:paddingEnd="16dp"
                android:paddingBottom="9dp"
                android:text="@string/player_follow"
                android:textColor="@android:color/white"
                android:textSize="14sp"
                android:textStyle="bold" />
        </LinearLayout>

        <TextView
            android:id="@+id/mNowPlayingLabel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:maxLines="2"
            android:text="@string/player_empty"
            android:textColor="@color/bili_text_primary"
            android:textSize="24sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/mStatusLabel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/player_status_loading"
            android:textColor="@color/bili_text_secondary"
            android:textSize="13sp" />


        <TextView
            android:id="@+id/mSectionTitleLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:text="@string/player_section_channels"
            android:textColor="@color/bili_text_primary"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/mSourceHintLabel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="@string/player_section_desc"
            android:textColor="@color/bili_text_secondary"
            android:textSize="13sp" />
    </LinearLayout>

    <com.scwang.smart.refresh.layout.SmartRefreshLayout
        android:id="@+id/mSmartRefreshLayout"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/mRecyclerView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:paddingStart="16dp"
            android:paddingTop="12dp"
            android:paddingEnd="16dp"
            android:paddingBottom="24dp" />
    </com.scwang.smart.refresh.layout.SmartRefreshLayout>
</LinearLayout>
